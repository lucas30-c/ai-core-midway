{
  "name": "@luyu/tech-debt",
  "version": "0.1.0",
  "description": "AI-powered technical debt analyzer for Git diffs",
  "type": "commonjs",
  "bin": {
    "tech-debt": "dist/cli/index.js"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "dependencies": {
    "@midwayjs/bootstrap": "^3.12.0",
    "@midwayjs/core": "^3.12.0",
    "@midwayjs/info": "^3.12.0",
    "@midwayjs/koa": "^3.12.0",
    "@midwayjs/logger": "^3.1.0",
    "@midwayjs/validate": "^3.20.22",
    "better-sqlite3": "^12.6.2",
    "commander": "^11.1.0",
    "dotenv": "^17.3.1",
    "execa": "^5.1.1",
    "minimatch": "^9.0.0",
    "ts-morph": "^22.0.0",
    "typescript": "~4.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@midwayjs/mock": "^3.12.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.2.0",
    "@types/node": "14",
    "cross-env": "^6.0.0",
    "eslint": "^7.32.0",
    "jest": "^29.2.2",
    "mwts": "^1.3.0",
    "mwtsc": "^1.4.0",
    "ts-jest": "^29.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "technical-debt",
    "code-quality",
    "typescript",
    "git",
    "analysis",
    "cli"
  ],
  "scripts": {
    "start": "NODE_ENV=production node ./bootstrap.js",
    "dev": "cross-env NODE_ENV=local mwtsc --watch --run @midwayjs/mock/app.js",
    "test": "cross-env NODE_ENV=unittest jest",
    "cov": "jest --coverage",
    "lint": "mwts check",
    "lint:fix": "mwts fix",
    "ci": "npm run cov",
    "build": "mwtsc --cleanOutDir",
    "ci:tech-debt": "git fetch origin main && node dist/cli/index.js analyze --git-range origin/main..HEAD --fail-on warning --out tech-debt-report.md",
    "prepublishOnly": "npm run build && npm test && npm run lint",
    "release:dry": "npm pack --dry-run",
    "release:pack": "npm pack"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lucas30-c/ai-core-midway.git"
  },
  "homepage": "https://github.com/lucas30-c/ai-core-midway#readme",
  "bugs": {
    "url": "https://github.com/lucas30-c/ai-core-midway/issues"
  },
  "author": "anonymous",
  "license": "MIT"
}
